  * def suffix = RandomDataUtil.randomAlphanumeric(6)
  * def title = 'KT java util task ' + suffix
  * def description = 'Task title contains a Java-generated random suffix'
  * def payload = read('classpath:examples/payloads/create-task.json')

  # Use the generated values in the request body.
  Given path 'api', 'v2', 'tasks'
  And request payload
  When method post
  Then status 201
